# ═══════════════════════════════════════════════════════════════
# Agntly — AI Agent Marketplace Platform
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://agntly:agntly@localhost:5432/agntly
REDIS_URL=redis://localhost:6379

# ── Supabase Auth ─────────────────────────────────────────────
# Find these in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key-here
# Used by api-gateway to verify Supabase JWTs
SUPABASE_URL=https://your-project-id.supabase.co

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-characters-long-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
COMPLETION_TOKEN_SECRET=your-completion-token-secret-min-32-chars

# ── Platform API key (master key used internally between services)
AGNTLY_API_KEY=agntly_your-internal-master-key-here

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Payments (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Blockchain (Base L2) ──────────────────────────────────────
# Sandbox environment uses Base Sepolia (NODE_ENV=development)
# Production environment uses Base mainnet (NODE_ENV=production)

# Base Sepolia RPC (sandbox / testnet)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Base mainnet RPC (production) — use a paid RPC for reliability in prod
# e.g. Alchemy: https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org

# Relayer/deployer private key — this wallet pays gas for on-chain settlements
# Fund with ETH: ≥0.005 ETH on mainnet, ≥0.001 ETH on Sepolia
PRIVATE_KEY=0xyour-deployer-wallet-private-key
RELAYER_PRIVATE_KEY=0xyour-relayer-wallet-private-key

# USDC contract addresses (do not change unless Circle changes them)
# Sandbox (Base Sepolia): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Production (Base mainnet): 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Deployed contract addresses — filled in after running deploy/sandbox.ts or deploy/production.ts
ESCROW_CONTRACT_ADDRESS=
WALLET_FACTORY_ADDRESS=
REGISTRY_CONTRACT_ADDRESS=

# Fee collector address — receives the 3% platform fee from escrow settlements
# Use a multisig in production. Defaults to deployer address if not set.
FEE_COLLECTOR_ADDRESS=

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com

# ── Service URLs (internal, change only for distributed deploy)
AUTH_SERVICE_URL=http://localhost:3001
WALLET_SERVICE_URL=http://localhost:3002
ESCROW_SERVICE_URL=http://localhost:3003
TASK_SERVICE_URL=http://localhost:3004
REGISTRY_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006
WEBHOOK_SERVICE_URL=http://localhost:3007

# ── Environment ───────────────────────────────────────────────
# development → sandbox (Base Sepolia, ag_test_sk_ API keys)
# production  → live (Base mainnet, ag_live_sk_ API keys)
NODE_ENV=development
LOG_LEVEL=info
